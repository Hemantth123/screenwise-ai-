# ─────────────────────────────────────────────────────────────────────────────
# ScreenWise — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (local dev) or set these in your Vercel project's
# Environment Variables settings (Production + Preview + Development).
#
# The prototype is stateless and needs NO database. The only required env vars
# are the ZAI credentials below so the /api/screen endpoint can call the LLM.
# ─────────────────────────────────────────────────────────────────────────────

# ZAI API credentials — REQUIRED for the AI screening endpoint to work.
# Get these from your Z.ai dashboard or the .z-ai-config file in your dev env.
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://internal-api.z.ai/v1

# Optional — used by the ZAI SDK for session tracking. Leave blank if unsure.
ZAI_CHAT_ID=
ZAI_USER_ID=
ZAI_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — only needed if you switch from ZAI to OpenAI/Anthropic later.
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
